<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.collegeems.dao.ResumeDao">



    <!-- 根据ID查询简历 -->
    <select id="findById" parameterType="java.lang.Long" resultType="com.example.collegeems.entity.Resume">
        SELECT * FROM resumes
        WHERE id = #{id}
    </select>

    <!-- 插入简历 -->
    <insert id="save" parameterType="com.example.collegeems.entity.Resume" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO resumes (
            user_id,
            resume_photo,
            content,
            created_at,
            updated_at,
            name,
            gender,
            birthday,
            education,
            school,
            major,
            skills,
            experience,
            projects,
            resume_url
        ) VALUES (
                     #{userId},
                     #{resumePhoto},
                     #{content},
                     #{createdAt},
                     #{updatedAt},
                     #{name},
                     #{gender},
                     #{birthday},
                     #{education},
                     #{school},
                     #{major},
                     #{skills},
                     #{experience},
                     #{projects},
                     #{resumeUrl}
                 )
    </insert>

    <!-- 更新简历 -->
    <update id="update" parameterType="com.example.collegeems.entity.Resume">
        UPDATE resumes
        SET user_id = #{userId},
            resume_photo = #{resumePhoto},
            content = #{content},
            updated_at = #{updatedAt},
            name = #{name},
            gender = #{gender},
            birthday = #{birthday},
            education = #{education},
            school = #{school},
            major = #{major},
            skills = #{skills},
            experience = #{experience},
            projects = #{projects},
            resume_url = #{resumeUrl}
        WHERE id = #{id}
    </update>

    <!-- 删除简历 -->
    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM resumes
        WHERE id = #{id}
    </delete>

    <!-- 根据搜索条件查询简历 -->
    <select id="findBySearch" resultType="com.example.collegeems.entity.Resume">
        SELECT *
        FROM resumes
        <where>
            <if test="params != null">
                <if test="params.name != null and params.name != ''">
                    AND name LIKE CONCAT('%', #{params.name}, '%')
                </if>
                <if test="params.education != null and params.education != ''">
                    AND education LIKE CONCAT('%', #{params.education}, '%')
                </if>
            </if>
        </where>
    </select>

    <select id="findByUserId" parameterType="java.lang.Long" resultType="com.example.collegeems.entity.Resume">
        SELECT * FROM resumes
        WHERE user_id = #{userId}
    </select>




</mapper>